# Example environment variables for local development or Render.
# Copy to Node/.env and fill values (do not commit secrets).

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecommerce?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_strong_secret_here
STRIPE_SECRET_KEY=sk_test_your_hidden_key_here
CLIENT_URL=http://localhost:5173
HOST_EMAIL=host@ecommerce.local
HOST_PASSWORD=hostpass123
SEED_INITIAL_HOST_ITEMS=true
PORT=5000
