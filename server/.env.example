# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Required)
MONGODB_URI=mongodb://localhost:27017/ecommerce

# JWT Configuration (Required - must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Stripe Configuration (Optional - for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Frontend Configuration
CLIENT_URL=http://localhost:5173

# Security Notes:
# 1. Use a strong JWT_SECRET with at least 32 characters
# 2. In production, use HTTPS for CLIENT_URL
# 3. Keep STRIPE_SECRET_KEY secure and never commit to version control
# 4. Use environment-specific MONGODB_URI for different environments
